2024/12/16 13:39:59 Commit: {"did":"did:plc:gzg3h5hprb74kz2igyghudlb","time_us":1734356399807843,"kind":"commit","commit":{"rev":"3ldghclu2ar2d","operation":"create","collection":"app.bsky.feed.post","rkey":"3ldghcjawrc25","record":{"$type":"app.bsky.feed.post","createdAt":"2024-12-16T13:39:56.897Z","langs":["en"],"reply":{"parent":{"cid":"bafyreiba2mitzzjs7px5twb6gcnu5qxgr5lzd5deelidgurvsx2hjp2e6q","uri":"at://did:plc:ifsxki4ut2w7bk6t5k4ndtuc/app.bsky.feed.post/3ldgfraiuzc2k"},"root":{"cid":"bafyreibbqwck4jupdvlc7hc6fmnra27bardpfafzefpwxwkc45ylnrciru","uri":"at://did:plc:ifsxki4ut2w7bk6t5k4ndtuc/app.bsky.feed.post/3ldgfraihds2k"}},"text":"What a great question! \nI am so attracted to the lights and the beauty of the holidays.\nI love shiny things. \nAs a wee girl in the early 1960s, I much fell in love with Coca-Cola classic Santa Claus. A soft and loving rendition of Santa plus Coke🎅, tho I never tried cola till I moved to the States."},"cid":"bafyreigxfj7olm3ibep2beup6nxbnben544rsipigkd56mukwnobgn5moe"}}
