2024/12/16 12:57:19 Commit: {"did":"did:plc:ilujdnn2x4krp6js6b4uc2tq","time_us":1734353839831308,"kind":"commit","commit":{"rev":"3ldgewbvyph2w","operation":"create","collection":"app.bsky.feed.post","rkey":"3ldgevtwvfs2f","record":{"$type":"app.bsky.feed.post","createdAt":"2024-12-16T12:57:04.409Z","embed":{"$type":"app.bsky.embed.images","images":[{"alt":"A map of the area subject to the advice","aspectRatio":{"height":2000,"width":1013},"image":{"$type":"blob","ref":{"$link":"bafkreibzkym343edwyu3oxdtjr65w5svdqwk65uqwju62r5pn3ch3n6x64"},"mimeType":"image/jpeg","size":940948}},{"alt":"Watch and Act - Bushfire - Leave Now\nClose popup\nIssued Today at 11:23 PM.\n\nThis Watch and Act message is being issued for Dean, Springmount, Wattle Flat.\n\nThere is a bushfire at Melbourne Rd, Creswick that is not yet under control. \nThe bushfire is travelling from Melbourne Road, Creswick in a north-easterly direction towards Sawmill Road, Springmount. \nDon't wait, leaving now is the safest option - conditions may change and get worse very quickly. Emergency services may not be able to help you if you decide to stay. \nWhat you should do: \nMonitor changes to the situation. Increased wind speed, change in wind direction, smoke or poor visibility can indicate the situation is changing.\nProtect yourself and your family. \nIf you are away from home, do not return.\n\nIf the situation changes or you feel unsafe you should leave:\nTake your pets, medications, mobile phone and charger.\nMany people have died trying to leave at the last minute during fires. \nTravel to the home of family or friends that are away from the warning area.\nImpacts in your area: \n\nRoad Closures:\nCreswick Dean Road between Melbourne Road and Ballarat Daylesford Road.\nMelbourne Road between Creswick Dean Road and Wattle Flat Road.\nBungaree-Daylesford Road between Wattle Flat Road and Ballarat-Daylesford Road.\nBallarat-Daylesford Road between Madderns Road and Bungaree Creswick Road.\nMadderns Road between Ballarat- Daylesford Road and Clarkes Road.\nClarkes Road between Madderns Road and Longs Hills Road.\nSawmill Road between Midland Hwy and Ballarat-Daylesford Road\nCheck the VicTraffic website (traffic.vicroads.vic.gov.au/) or call 13 11 70 for road closures.\n\nRelief Centre:\nA Relief Centre is open at Doug Lindsay Reserve, Lindsay Park Drive, Creswick.\n\n\n\n","aspectRatio":{"height":2000,"width":323},"image":{"$type":"blob","ref":{"$link":"bafkreiffqb2ao52mi2i3y3f7w4nfyorlcskthanu6jfxxvlwh5grzpmf6q"},"mimeType":"image/jpeg","size":343507}}]},"facets":[{"features":[{"$type":"app.bsky.richtext.facet#link","uri":"https://emergency.vic.gov.au/respond/#!/warning/34951/moreinfo"}],"index":{"byteEnd":231,"byteStart":195}}],"langs":["en"],"text":"⚠️Watch and Act - Bushfire - Leave Now for Dean, Springmount, Wattle Flat.\n\nDon't wait, leaving now is the safest option - conditions may change and get worse very quickly. \n\nMore details at emergency.vic.gov.au/respond/#!/w..."},"cid":"bafyreif2qic6fqdckvuivxvcsdaz4hr2gjs2gsqs7e4u6ae3smrwoinzdm"}}
